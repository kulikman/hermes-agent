#!/usr/bin/env bash
COMMIT_MSG_FILE=$1
if grep --quiet --extended-regexp " into |^Merge " "$COMMIT_MSG_FILE"; then exit 0; fi
COMMIT_MSG=$(cat "$COMMIT_MSG_FILE")
CONVENTIONAL_COMMIT_REGEX='^(feat|fix|docs|style|refactor|test|chore|build|ci|perf|revert)(\([a-zA-Z0-9_.-]+\))?(!)?:[[:space:]].*$'
if ! [[ $COMMIT_MSG =~ $CONVENTIONAL_COMMIT_REGEX ]]; then
    echo "ERROR: Conventional Commits required. Types: feat fix docs style refactor test chore build ci perf revert"
    exit 1
fi
if command -v pnpm &> /dev/null && [ -f "package.json" ]; then pnpm exec commitlint --edit "$1" 2>/dev/null || true; fi
